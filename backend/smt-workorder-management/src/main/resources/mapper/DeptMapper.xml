<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aircookies.smtworkordermanagement.mapper.DeptMapper">

    <!--    添加部门-->
    <insert id="addDept" parameterType="com.aircookies.smtworkordermanagement.entity.Dept" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO dept (name,
                          create_time,
                          update_time)
        VALUES (#{name},
                #{createTime},
                #{updateTime})
    </insert>
    <!--    更新部门-->
    <update id="updateDept">
        UPDATE dept
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>
    <!--    删除部门-->
    <delete id="deleteDept">
        DELETE
        FROM dept
        WHERE id = #{id}
    </delete>
    <!--    查询部门-->
    <select id="findDept" resultType="com.aircookies.smtworkordermanagement.entity.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        <where>
            <if test="name != null">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="id != null">
                AND id = #{id}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>
<!--    通过名称查询部门-->
    <select id="findDeptByName" resultType="com.aircookies.smtworkordermanagement.entity.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        WHERE name = #{name}
    </select>
    <!--    通过ID查询部门-->
    <select id="findDeptById" resultType="com.aircookies.smtworkordermanagement.entity.Dept">
        SELECT id,
               name,
               create_time,
               update_time
        FROM dept
        WHERE id = #{id}
    </select>

</mapper>
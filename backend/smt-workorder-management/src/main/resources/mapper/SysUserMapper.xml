<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.aircookies.smtworkordermanagement.mapper.SysUserMapper">

    <!-- 添加用户 -->
    <insert id="addUser" parameterType="com.aircookies.smtworkordermanagement.entity.SysUser" useGeneratedKeys="true"
            keyProperty="id">
        INSERT INTO sys_user (username,
                              password,
                              name,
                              gender,
                              role_id,
                              department_id,
                              status,
                              create_time,
                              update_time)
        VALUES (#{username},
                #{password},
                #{name},
                #{gender},
                #{roleId},
                #{departmentId},
                #{status},
                NOW(),
                NOW())
    </insert>

    <!-- 根据ID查询用户 -->
    <select id="findUser" resultType="com.aircookies.smtworkordermanagement.entity.SysUser">
        SELECT id,
               username,
               password,
               name,
               gender,
               role_id,
               department_id,
               status,
               create_time,
               update_time
        FROM sys_user
        WHERE id = #{id}
    </select>

    <!-- 查询所有用户 -->
    <select id="findAll" resultType="com.aircookies.smtworkordermanagement.entity.SysUser">
        SELECT id,
               username,
               password,
               name,
               gender,
               role_id,
               department_id,
               status,
               create_time,
               update_time
        FROM sys_user
        ORDER BY create_time DESC
    </select>
    <!--    查询所有满足条件的用户-->
    <select id="UserList" resultType="com.aircookies.smtworkordermanagement.entity.SysUser">
        SELECT id,
               username,
               password,
               name,
               gender,
               role_id,
               department_id,
               status,
               create_time,
               update_time
            FROM sys_user
        <where>
            <if test="name != null">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="gender != null">
                AND gender = #{gender}
            </if>
            <if test="roleId != null">
                AND role_id = #{roleId}
            </if>
            <if test="departmentId != null">
                AND department_id = #{departmentId}
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <!-- 更新用户 -->
    <update id="updateUser" parameterType="com.aircookies.smtworkordermanagement.entity.SysUser">
        UPDATE sys_user
        <set>
            <if test="username != null and username != ''">
                username = #{username},
            </if>
            <if test="password != null and password != ''">
                password = #{password},
            </if>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="gender != null and gender != ''">
                gender = #{gender},
            </if>
            <if test="roleId != null and roleId != ''">
                role_id = #{roleId},
            </if>
            <if test="departmentId != null and departmentId != ''">
                department_id = #{departmentId},
            </if>
            <if test="status != null and status != ''">
                status = #{status},
            </if>
            <if test="updateTime != null">
                update_time = #{updateTime},
            </if>
        </set>
        WHERE id = #{id}
    </update>

    <!-- 删除用户 -->
    <delete id="deleteUser">
        DELETE
        FROM sys_user
        WHERE id IN
        <foreach item="id" collection="ids" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
